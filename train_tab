#!/usr/bin/env bash
set -euo pipefail

latest_log="$(ls -1t calibration_logs/tab_calibration_*.json 2>/dev/null | head -n 1 || true)"
if [[ -z "$latest_log" ]]; then
  echo "No tab calibration logs found."
  echo "Run: uv run python tab_calibration.py"
  exit 1
fi

bash run_codex_tab_log_tuning.sh --log-file "$latest_log" "$@"
