{
  "manifest_version": 3,
  "name": "Tab Calibration Overlay",
  "version": "1.0.0",
  "description": "Marks the active calibration tab by prefixing its title with a red dot.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": []
}
